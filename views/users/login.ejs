<% layout('/layouts/boilerplate.ejs') -%>
<body>
  <%- include('../includes/navbar.ejs') -%>
  <%- include('../includes/flash.ejs') -%>

  <div class="bg-page auth-bg">
    <div class="container py-5">

      <h2 class="page-title text-center mb-4">Log in</h2>

      <div class="row justify-content-center">
        <div class="col-12 col-sm-10 col-md-6 col-lg-5">

          <div class="auth-card shadow-sm">

            <form action="/login" method="POST" class="needs-validation" novalidate>

              <!-- Username -->
              <div class="mb-3">
                <label class="form-label">Username</label>
                <input
                  type="text"
                  class="form-control auth-input"
                  name="username"
                  required
                >
                <div class="valid-feedback">Looks good!</div>
                <div class="invalid-feedback">
                  Please enter your username.
                </div>
              </div>

              <!-- Password -->
              <div class="mb-4">
                <label class="form-label">Password</label>
                <input
                  type="password"
                  class="form-control auth-input"
                  name="password"
                  required
                >
                <div class="valid-feedback">Password entered.</div>
                <div class="invalid-feedback">
                  Password is required.
                </div>
              </div>

              <div class="d-grid">
                <button class="btn add-btn auth-btn">
                  Log in
                </button>
              </div>

            </form>

            <p class="text-center mt-3 mb-0 auth-footer-text">
              Don’t have an account?
              <a href="/signup" class="auth-link">Sign up</a>
            </p>

          </div>

        </div>
      </div>

    </div>
  </div>

  <%- include('../includes/footer.ejs') -%>
</body>
